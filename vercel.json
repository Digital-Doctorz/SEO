{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300,
      "includeFiles": "{dist/**,prompts/**}"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api|_next|assets|favicon|robots|sitemap|og-image|\\.css|\\.js).*)",
      "destination": "/index.html"
    }
  ]
}
